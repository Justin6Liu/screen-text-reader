<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/textPrimary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/setup_subtitle"
            android:textColor="@color/textSecondary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/panel_background"
            android:padding="16dp"
            android:textColor="@color/textPrimary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/speechStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/panel_background"
            android:padding="16dp"
            android:textColor="@color/textPrimary"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/debugModeCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/debug_mode_label"
            android:textColor="@color/textPrimary"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/saveDebugScreenshotsCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/save_debug_screenshots_label"
            android:textColor="@color/textPrimary"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/recognizedTextConsoleCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/recognized_text_console_label"
            android:textColor="@color/textPrimary"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/highlightReadingLineCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/highlight_reading_line_label"
            android:textColor="@color/textPrimary"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/pauseResumeReadingCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/pause_resume_reading_label"
            android:textColor="@color/textPrimary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/overlayPermissionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/grant_overlay_permission" />

        <Button
            android:id="@+id/accessibilityButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/open_accessibility_settings" />

        <Button
            android:id="@+id/batteryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/open_battery_settings" />

        <Button
            android:id="@+id/startOverlayButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/start_overlay" />

        <Button
            android:id="@+id/stopOverlayButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/stop_overlay" />

        <Button
            android:id="@+id/testReadButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/test_speech" />

        <Button
            android:id="@+id/stopSpeechButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/stop_speech" />

        <TextView
            android:id="@+id/recognizedTextConsoleTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/recognized_text_console_title"
            android:textColor="@color/textPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/recognizedTextConsoleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/panel_background"
            android:padding="16dp"
            android:textColor="@color/textPrimary"
            android:textIsSelectable="true"
            android:textSize="16sp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
