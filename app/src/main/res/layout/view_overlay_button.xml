<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <ImageButton
        android:id="@+id/overlayButton"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/overlay_button_background"
        android:contentDescription="@string/overlay_button_read_label"
        android:padding="18dp"
        android:src="@drawable/ic_overlay_play"
        android:tint="@android:color/white" />

    <TextView
        android:id="@+id/overlayLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/overlay_label_background"
        android:paddingLeft="10dp"
        android:paddingTop="4dp"
        android:paddingRight="10dp"
        android:paddingBottom="4dp"
        android:text="@string/overlay_button_read_text"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/overlayProgressPanel"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/panel_background"
        android:orientation="vertical"
        android:paddingLeft="12dp"
        android:paddingTop="8dp"
        android:paddingRight="12dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/overlayProgressText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/textPrimary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/overlayProgressSeekBar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:max="1000" />
    </LinearLayout>
</LinearLayout>
